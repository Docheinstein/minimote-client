<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav"
    app:startDestination="@id/naviServers">
    <fragment
        android:id="@+id/naviServers"
        android:name="org.docheinstein.minimote.servers.ServersFragment"
        tools:layout="@layout/servers">
        <action
            android:id="@+id/actionEditServer"
            app:destination="@id/naviEditServer"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
        <action
            android:id="@+id/actionController"
            app:destination="@id/naviController"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>
    <fragment
        android:id="@+id/naviEditServer"
        android:name="org.docheinstein.minimote.edit.EditServerFragment"
        tools:layout="@layout/edit_server">
        <argument
            android:name="serverAddress"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/naviController"
        android:name="org.docheinstein.minimote.controller.MinimoteControllerFragment"
        tools:layout="@layout/controller">
        <argument
            android:name="serverAddress"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/naviHotkeys"
        android:name="org.docheinstein.minimote.hotkeys.HotkeysFragment"
        android:label="Hotkeys">
        <action
            android:id="@+id/actionAddEditHotkey"
            app:destination="@id/naviHotkey" />
    </fragment>

    <fragment
        android:id="@+id/naviHotkey"
        android:name="org.docheinstein.minimote.hotkeys.AddEditHotkeyFragment"
        android:label="Hotkey">
        <argument
            android:name="hotkeyId"
            app:argType="integer" />
    </fragment>
    <fragment
        android:id="@+id/naviSettings"
        android:name="org.docheinstein.minimote.settings.SettingsFragment"
        android:label="Settings" />
    <action
        android:id="@+id/actionSettings"
        app:destination="@id/naviSettings"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim" />
    <action
        android:id="@+id/actionServers"
        app:destination="@id/naviServers"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim" />
    <action
        android:id="@+id/actionHotkeys"
        app:destination="@id/naviHotkeys"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim" />
</navigation>