<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/textView12"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Preview"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/uiHotkeyPreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:background="@drawable/touchpad_button_selector"
        android:text="TextView" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Modifiers"
        android:textSize="26sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/uiModifierCtrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CTRL"
        android:textSize="18sp" />

    <CheckBox
        android:id="@+id/uiModifierAlt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ALT"
        android:textSize="18sp" />

    <CheckBox
        android:id="@+id/uiModifierAltGr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ALT GR"
        android:textSize="18sp" />

    <CheckBox
        android:id="@+id/uiModifierMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="META"
        android:textSize="18sp" />

    <CheckBox
        android:id="@+id/uiModifierShift"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SHIFT"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Key"
        android:textSize="26sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/uiKey"
        style="@android:style/Widget.DeviceDefault.Light.Spinner"
        android:layout_width="match_parent"

        android:layout_height="wrap_content"
        android:entries="@array/keys" />


    <TextView
        android:id="@+id/textView9"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Style"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textView13"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Display name"
        android:textSize="18sp" />

    <EditText
        android:id="@+id/uiHotkeyName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Text size"
        android:textSize="18sp" />

    <SeekBar
        android:id="@+id/uiTextSize"
        style="@style/Widget.AppCompat.SeekBar.Discrete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="24"
        android:progress="9" />

    <TextView
        android:id="@+id/textView10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Padding"
        android:textSize="18sp" />

    <SeekBar
        android:id="@+id/uiPadding"
        style="@style/Widget.AppCompat.SeekBar.Discrete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="24"
        android:progress="13" />


</LinearLayout>