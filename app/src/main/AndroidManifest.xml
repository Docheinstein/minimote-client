<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.docheinstein.minimote">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/minimote_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/minimote_icon_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.server.EditServerFragment" />
        <activity android:name=".ui.servers.ServersFragment" />
        <activity
            android:name=".ui.controller.MinimoteControllerFragment"
            />
        <!--        <activity android:name=".controller.ControllerActivity" />-->
        <!--            android:windowSoftInputMode="adjustPan"-->
    </application>

</manifest>